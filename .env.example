APP_NAME=Stock Market Data Platform
ENVIRONMENT=local

GATEWAY_PORT=8080
BACKEND_PORT=8000
FRONTEND_PORT=3000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=stock_dw
POSTGRES_USER=stock_user
POSTGRES_PASSWORD=stock_password

SCYLLA_HOSTS=scylla
SCYLLA_KEYSPACE=stock_online_store
SCYLLA_LOCAL_DC=datacenter1
SCYLLA_CQL_PORT=9042
SCYLLA_API_PORT=10000

NEXT_PUBLIC_API_BASE_URL=/api

LOG_LEVEL=INFO
LOG_DIR=logs

KAFKA_EXTERNAL_PORT=9094
KAFKA_NUM_PARTITIONS=3
KAFKA_RAW_STOCK_TOPIC=raw_stock_events
KAFKA_CONSUMER_GROUP=stock-scylla-writer
STOCK_SYMBOLS=AAPL,MSFT,NVDA
PRODUCER_INTERVAL_SECONDS=2

NEWS_SOURCES=mock_market_news
NEWS_SCRAPE_INTERVAL_SECONDS=300
NEWS_ETL_INTERVAL_SECONDS=300
NEWS_ETL_START_DELAY_SECONDS=10
